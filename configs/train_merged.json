    "inlet_conversion_threshold": 0.05,
    "inlet_weight": 5.0,
    "species_weights": {
      "C2H4": 150,
      "C3H6": 100,
      "CH4": 20,
      "H2": 10
    },
    "composition_feature_range": [
      0.0,
      1.0
    ],
    "seed": 0,
    "energy_active_coverage": 0.999,
    "mech_yaml": "chem_ForTransport.yaml",
    "tail_strata": 10,
    "tail_weight_alpha": 2.0,
    "columns_projection": true,
    "composition_sigma_floor": 1e-10
  },
  "model": {
    "kind": "merged",
    "latent_dim": 8,
    "decoder_hidden": [
