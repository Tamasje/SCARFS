{
  "_comment": "Parent-2 baseline: our-architecture NeuralCoil mimic (kind='neuralcoil', k=3, retained-species input). No dedicated energy head — energy is scored from rate-derived absorption at benchmark time (absorption_from_rates(predicted_rates, T)). This is exactly the RC-3 free-head pathology we are fixing; the mimic baseline is used only for comparison. Train on the same 70/15/15 splits as the merged model.",
  "data": {
    "database_path": "Database_FINAL.parquet",
    "input_species": "active",
    "target_species": "active",
    "val_fraction": 0.176,
    "test_fraction": 0.15,
    "split_by_case": true,
    "inlet_conversion_threshold": 0.05,
    "inlet_weight": 5.0,
    "species_weights": {"C2H4": 150, "C3H6": 100, "CH4": 20, "H2": 10},
    "composition_feature_range": [0.0, 1.0],
    "seed": 0,
    "energy_active_coverage": 0.999,
    "mech_yaml": "chem_ForTransport.yaml",
    "tail_strata": 0,
    "tail_weight_alpha": 2.0,
    "columns_projection": false
  },
  "model": {
    "kind": "neuralcoil",
    "latent_dim": 3,
    "decoder_hidden": [128, 256],
    "rate_hidden": [128, 128],
    "activation": "silu",
    "spectral_norm": false
  },
  "optim": {
    "lr": 0.001,
    "weight_decay": 1e-6,
    "epochs": 300,
    "batch_size": 4096,
    "grad_clip": 1.0,
    "patience": 30
  },
  "loss": {
    "recon_weight": 1.0,
    "manifold_weight": 0.1,
    "noise_std": 0.05,
    "unroll_steps": 1,
    "atom_balance_weight": 0.0
  },
  "output_dir": "runs/merged_mimic"
}
